@model IEnumerable<NorthwindApp.Models.Product>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 text-primary">Products Catalog</h1>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success px-4 py-2 shadow-sm">
                <i class="bi bi-plus-circle"></i> Create New Product
            </a>
        }
    </div>
    @if (TempData["CartMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["CartMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form -->
    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-6 col-lg-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control border-start-0" placeholder="Search by product name or category..." aria-label="Search" />
                    </div>
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary px-4">Search</button>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary px-3">Clear</a>
                    }
                </div>
            </form>
        </div>
    </div>

    <!-- Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Product Name</th>
                            <th>Category</th>
                            <th>Quantity Per Unit</th>
                            <th>Unit Price</th>
                            <th>Units In Stock</th>
                            <th>Units On Order</th>
                            <th>Supplier</th>
                            <th class="text-end pe-4" style="min-width: 220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-info-circle display-6 mb-3 d-block"></i> No products found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@item.Productname</td>
                                    <td>
                                        <span class="badge bg-secondary">@(item.Category?.Categoryname ?? "None")</span>
                                    </td>
                                    <td>@item.Quantityperunit</td>
                                    <td class="text-success fw-bold">
                                        @string.Format("{0:C}", item.Unitprice)
                                    </td>
                                    <td>@item.Unitsinstock</td>
                                    <td>
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-flex gap-2 align-items-center">
                                            <input type="hidden" name="productId" value="@item.Productid" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                            <input type="number" name="quantity" value="1" min="1" max="@(item.Unitsinstock ?? 1)" class="form-control form-control-sm" style="width: 90px;" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Add</button>
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </td>
                                    <td>@item.Unitsonorder</td>
                                    <td>@(item.Supplier?.Companyname ?? "None")</td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Productid" class="btn btn-sm btn-outline-info" title="View Details">
                                                Details
                                            </a>
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Productid" class="btn btn-sm btn-outline-warning" title="Edit Product">
                                                    Edit
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.Productid" class="btn btn-sm btn-outline-danger" title="Delete Product">
                                                    Delete
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        var prevDisabled = !ViewBag.HasPreviousPage ? "disabled" : "";
        var nextDisabled = !ViewBag.HasNextPage ? "disabled" : "";

        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-center mt-4 mb-5">
            <div class="mb-3 mb-sm-0 text-muted">
                Showing page <span class="fw-bold text-dark">@ViewBag.CurrentPage</span> of <span class="fw-bold text-dark">@ViewBag.TotalPages</span>
            </div>
            <nav aria-label="Page navigation">
                <ul class="pagination mb-0 shadow-sm">
                    <li class="page-item @prevDisabled">
                        <a asp-action="Index"
                           asp-route-pageNumber="@(ViewBag.CurrentPage - 1)"
                           asp-route-searchString="@ViewBag.SearchString"
                           asp-route-pageSize="@ViewBag.PageSize"
                           class="page-link">
                            Previous
                        </a>
                    </li>

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        var activeClass = i == ViewBag.CurrentPage ? "active" : "";
                        <li class="page-item @activeClass">
                            <a asp-action="Index"
                               asp-route-pageNumber="@i"
                               asp-route-searchString="@ViewBag.SearchString"
                               asp-route-pageSize="@ViewBag.PageSize"
                               class="page-link">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @nextDisabled">
                        <a asp-action="Index"
                           asp-route-pageNumber="@(ViewBag.CurrentPage + 1)"
                           asp-route-searchString="@ViewBag.SearchString"
                           asp-route-pageSize="@ViewBag.PageSize"
                           class="page-link">
                            Next
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
